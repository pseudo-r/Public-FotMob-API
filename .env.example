# Django core
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=true

# Database
DATABASE_URL=postgres://fotmob:fotmob_pass@db:5432/fotmob_db

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# FotMob client
FOTMOB_BASE_URL=https://www.fotmob.com/api
FOTMOB_TIMEOUT=30.0
FOTMOB_MAX_RETRIES=3
FOTMOB_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Logging
LOGGING_LEVEL=INFO
